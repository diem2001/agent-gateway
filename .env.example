# Server
PORT=3001
HOST=0.0.0.0

# Auth — comma-separated label:key pairs
API_KEYS=default:changeme

# Logging (off | info | debug)
LOG_LEVEL=info

# Anthropic Authentication (choose one):
# Option A: OAuth (recommended) — run POST /v1/auth/login after startup, no key needed
# Option B: API Key — set the key below
# ANTHROPIC_API_KEY=sk-ant-...

# Sessions
SESSION_IDLE_TIMEOUT_MS=0
# Default: ./data/sessions.json (Docker override in docker-compose.yml)
# SESSION_PERSIST_PATH=/home/node/.claude/sessions.json

# Event cache TTL (default: 30 minutes)
# EVENT_CACHE_TTL_MS=1800000

# Workspace root for memory/agents/skills (default: $HOME/.claude)
# WORKSPACE_ROOT=/home/node/.claude

# Tool Registry (default: ./data/tools.json, Docker override in docker-compose.yml)
# TOOLS_PERSIST_PATH=/home/node/.claude/tools.json
